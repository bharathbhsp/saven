# =============================================================================
# Saven frontend — environment variables
# =============================================================================
# 1. Copy this file to .env:
#      cp .env.example .env
#
# 2. Populate values from your deployed infrastructure (Terraform outputs).
#    From the repo root, with infra already applied:
#
#    cd infra
#    terraform output
#
#    Then set each variable below to the corresponding output value.
# =============================================================================

# API base URL (no trailing slash). From: terraform -chdir=infra output -raw api_gateway_url
VITE_API_URL=https://YOUR_API_ID.execute-api.REGION.amazonaws.com

# Cognito User Pool ID. From: terraform -chdir=infra output -raw cognito_user_pool_id
# Example: ap-south-2_dCA6vBGvh
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client ID (the frontend app client). From: terraform -chdir=infra output -raw cognito_app_client_id
VITE_COGNITO_CLIENT_ID=

# Cognito Hosted UI domain prefix (no region, no .auth...). From: terraform -chdir=infra output -raw cognito_domain
# Example: saven-auth-prod — used to build login URL: https://<this>.auth.<region>.amazoncognito.com/login?...
VITE_COGNITO_DOMAIN=

# AWS region where Cognito and API Gateway are deployed. Must match your Terraform aws_region (e.g. ap-south-2).
VITE_AWS_REGION=ap-south-2
